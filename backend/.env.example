REDIS_URL=redis://localhost:6379/0

LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-9d346d1747de47c294f368f65
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
